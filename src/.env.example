# Telegram
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
ADMINS=123456789
BOT_NAME=TsuloVPN

# Публичный HTTPS-URL, по которому клиенты получают подписку
# Пример: https://vpn.example.com  (проксируйте порт SUBSCRIPTION_PORT через nginx/caddy)
SUBSCRIPTION_PUBLIC_URL=https://your-domain.com
SUBSCRIPTION_PORT=8080

# Источники goida-vpn-configs (менять не обязательно)
GOIDA_RAW_BASE=https://github.com/AvenCores/goida-vpn-configs/raw/refs/heads/main/githubmirror
WHITELIST_SOURCE_ID=26

# Сколько рабочих серверов отдавать в подписке
TARGET_REGULAR_COUNT=25
TARGET_WHITELIST_COUNT=7

# Как часто обновлять пул (секунды). goida обновляется каждые 9 минут
POOL_REFRESH_INTERVAL=600
HEALTH_CHECK_TIMEOUT=4.0
HEALTH_CHECK_CONCURRENCY=80
MAX_HEALTH_CHECK_CANDIDATES=400

DATABASE_URL=sqlite:///tsulovpn.db
