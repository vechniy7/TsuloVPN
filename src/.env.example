# Telegram
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
ADMINS=123456789
BOT_NAME=TsuloVPN

# Публичный HTTPS-URL подписки (Render: https://ваш-сервис.onrender.com)
SUBSCRIPTION_PUBLIC_URL=https://your-domain.com
SUBSCRIPTION_PORT=8080

# igareck/vpn-configs-for-russia (конфиги тестируются в РФ)
IGARECK_RAW_BASE=https://raw.githubusercontent.com/igareck/vpn-configs-for-russia/refs/heads/main

# Сколько серверов в подписке
TARGET_REGULAR_COUNT=25
TARGET_WHITELIST_COUNT=7

# igareck уже проверяет конфиги — доп. проверка с Render не нужна
SKIP_HEALTH_CHECK=true
POOL_REFRESH_INTERVAL=3600

DATABASE_URL=sqlite:///tsulovpn.db
