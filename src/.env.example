# Telegram
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
ADMINS=123456789
BOT_NAME=TsuloVPN

# Публичный HTTPS-URL подписки (Render: https://ваш-сервис.onrender.com)
SUBSCRIPTION_PUBLIC_URL=https://your-domain.com
SUBSCRIPTION_PORT=8080

# URL источника обычных VPN (RAW-файлы)
CONFIG_RAW_BASE=https://your-config-source-url/raw/main

# Единственный источник обходов белых списков (bypass-all.txt)
BYPASS_SOURCE_URL=https://raw.githubusercontent.com/whoahaow/rjsxrd/main/githubmirror/bypass/bypass-all.txt

# Сколько серверов в подписке
TARGET_REGULAR_COUNT=20
TARGET_WHITELIST_COUNT=15

# false = проверять пинг перед добавлением в подписку
SKIP_HEALTH_CHECK=false
# БС: Reality/grpc/ws проверяются только по TCP (не TLS)
WHITELIST_TCP_ONLY_CHECK=true
# БС не отсекаются при обновлении подписки в Happ
WHITELIST_SKIP_VERIFY_ON_SUBSCRIBE=true
WHITELIST_PER_PRIORITY_SNI=3
# true = повторная проверка обычного VPN при обновлении подписки
VERIFY_ON_SUBSCRIBE=true
POOL_REFRESH_INTERVAL=3600

DATABASE_URL=sqlite:///tsulovpn.db
